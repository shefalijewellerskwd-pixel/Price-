<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shefali Jewellers</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: #0d0d0d;
    color: white;
}

/* HEADER */
.header {
    background: linear-gradient(135deg, gold, orange);
    color: black;
    padding: 15px;
    border-radius: 0 0 20px 20px;
    text-align: center;
}

.header h1 {
    font-size: 22px;
}

.header p {
    font-size: 12px;
}

/* CARD */
.card {
    background: #1a1a1a;
    margin: 15px;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 0 10px rgba(255,215,0,0.2);
}

/* RATE BOX */
.rate {
    display: flex;
    justify-content: space-between;
    margin: 15px 0;
    font-size: 18px;
}

.badge {
    padding: 5px 10px;
    border-radius: 20px;
    font-size: 12px;
}

.up {
    background: #003d2e;
    color: #00ffae;
}

.down {
    background: #3d0000;
    color: #ff5c5c;
}

/* INPUT */
input {
    width: 100%;
    padding: 12px;
    margin: 8px 0;
    border-radius: 10px;
    border: none;
    background: #2a2a2a;
    color: white;
}

/* FLOAT BUTTON */
.fab {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: gold;
    color: black;
    border: none;
    padding: 15px 20px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: bold;
    box-shadow: 0 5px 15px rgba(255,215,0,0.4);
    cursor: pointer;
}

/* TITLE */
.title {
    margin-bottom: 10px;
    font-size: 16px;
    color: #aaa;
}
</style>

</head>

<body>

<div class="header">
    <h1>Shefali Jewellers</h1>
    <p>Chilphi Ghati Kawardha</p>
    <p>📞 9425736161 | 7999841492</p>
</div>

<div class="card">
    <div class="title">Today's Rates</div>

    <div class="rate">
        <span>Gold (10g)</span>
        <span id="goldDisplay">--</span>
    </div>

    <div class="rate">
        <span>Silver (1kg)</span>
        <span id="silverDisplay">--</span>
    </div>
</div>

<div class="card">
    <div class="title">Update Rates</div>

    <input type="number" id="goldRate" placeholder="Enter Gold Rate">
    <input type="number" id="silverRate" placeholder="Enter Silver Rate">
</div>

<button class="fab" onclick="updateRates()">Update</button>

<script>
let prevGold = localStorage.getItem("prevGold");
let prevSilver = localStorage.getItem("prevSilver");

function updateRates() {
    let gold = parseFloat(document.getElementById("goldRate").value);
    let silver = parseFloat(document.getElementById("silverRate").value);

    if (!gold || !silver) {
        alert("Enter both rates");
        return;
    }

    let goldDiff = prevGold ? gold - prevGold : 0;
    let silverDiff = prevSilver ? silver - prevSilver : 0;

    document.getElementById("goldDisplay").innerHTML =
        "₹" + gold + " " + formatDiff(goldDiff);

    document.getElementById("silverDisplay").innerHTML =
        "₹" + silver + " " + formatDiff(silverDiff);

    localStorage.setItem("prevGold", gold);
    localStorage.setItem("prevSilver", silver);

    prevGold = gold;
    prevSilver = silver;

    document.getElementById("goldRate").value = "";
    document.getElementById("silverRate").value = "";
}

function formatDiff(diff) {
    if (diff > 0) {
        return `<span class="badge up">↑ +${diff}</span>`;
    } else if (diff < 0) {
        return `<span class="badge down">↓ ${diff}</span>`;
    } else {
        return `<span class="badge">No Change</span>`;
    }
}

window.onload = function() {
    if (prevGold && prevSilver) {
        document.getElementById("goldDisplay").innerHTML = "₹" + prevGold;
        document.getElementById("silverDisplay").innerHTML = "₹" + prevSilver;
    }
}
</script>

</body>
</html>
